{
  "manifest_version": 3,
  "name": "QR Code Scanner",
  "description": "截取页面区域，识别其中的二维码内容",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "扫描二维码",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
